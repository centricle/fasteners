---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Comprehensive fastener specifications database - screws, bolts, anchors, and nuts." } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | fasteners.fyi</title>

    <!-- Open Graph -->
    <meta property="og:title" content={`${title} | fasteners.fyi`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:site_name" content="fasteners.fyi" />
    <meta property="og:image" content="https://fasteners.fyi/og-image.webp" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | fasteners.fyi`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://fasteners.fyi/og-image.webp" />

    <!-- SEO -->
    <link rel="canonical" href={Astro.url} />
    <meta name="robots" content="index, follow" />

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-7YTFBKYLFW"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-7YTFBKYLFW');
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    <header class="border-b border-bp-700 bg-bp-900/60 backdrop-blur-sm sticky top-0 z-50">
      <nav class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2">
          <div class="w-8 h-8 rounded-lg bg-bp-800 border border-bp-700 flex items-center justify-center">
            <svg class="w-5 h-5 text-accent-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="12,3 20.2,7.5 20.2,16.5 12,21 3.8,16.5 3.8,7.5"/>
              <circle cx="12" cy="12" r="3"/>
            </svg>
          </div>
          <span class="text-lg"><span class="text-accent-400">fasteners</span><span class="text-white font-bold">.fyi</span></span>
        </a>
        <!-- Desktop Navigation -->
        <div class="hidden md:flex gap-6 text-sm">
          <a href="/screws" class="text-bp-text-muted hover:text-bp-text transition-colors">Screws</a>
          <a href="/bolts" class="text-bp-text-muted hover:text-bp-text transition-colors">Bolts</a>
          <a href="/anchors" class="text-bp-text-muted hover:text-bp-text transition-colors">Anchors</a>
          <a href="/nuts" class="text-bp-text-muted hover:text-bp-text transition-colors">Nuts</a>
          <a href="/washers" class="text-bp-text-muted hover:text-bp-text transition-colors">Washers</a>
          <a href="/search" class="text-bp-text-muted hover:text-bp-text transition-colors">Search</a>
          <a href="/compare" class="text-bp-text-muted hover:text-bp-text transition-colors">Compare</a>
          <a href="/about" class="text-bp-text-muted hover:text-bp-text transition-colors">About</a>
        </div>

        <!-- Mobile Menu Button -->
        <button
          class="md:hidden flex items-center justify-center w-10 h-10 text-bp-text-muted hover:text-bp-text"
          aria-label="Open navigation menu"
          aria-expanded="false"
          id="mobile-menu-button"
        >
          <svg class="w-6 h-6 hamburger-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 5h16"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 12h16"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 19h16"/>
          </svg>
          <svg class="w-6 h-6 close-icon hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 6 6 18"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m6 6 12 12"/>
          </svg>
        </button>
      </nav>

      <!-- Mobile Navigation Menu -->
      <div class="md:hidden hidden" id="mobile-menu">
        <div class="px-4 pt-2 pb-3 space-y-1 border-t border-bp-700">
          <a href="/screws" class="block px-3 py-3 text-bp-text-muted hover:text-bp-text text-base font-medium">Screws</a>
          <a href="/bolts" class="block px-3 py-3 text-bp-text-muted hover:text-bp-text text-base font-medium">Bolts</a>
          <a href="/anchors" class="block px-3 py-3 text-bp-text-muted hover:text-bp-text text-base font-medium">Anchors</a>
          <a href="/nuts" class="block px-3 py-3 text-bp-text-muted hover:text-bp-text text-base font-medium">Nuts</a>
          <a href="/washers" class="block px-3 py-3 text-bp-text-muted hover:text-bp-text text-base font-medium">Washers</a>
          <a href="/search" class="block px-3 py-3 text-bp-text-muted hover:text-bp-text text-base font-medium">Search</a>
          <a href="/compare" class="block px-3 py-3 text-bp-text-muted hover:text-bp-text text-base font-medium">Compare</a>
          <a href="/about" class="block px-3 py-3 text-bp-text-muted hover:text-bp-text text-base font-medium">About</a>
        </div>
      </div>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="border-t border-bp-700 mt-auto">
      <div class="max-w-6xl mx-auto px-4 py-8">
        <div class="text-sm text-bp-text-faint text-center mb-4 flex flex-wrap justify-center gap-2 items-center">
          <span class="font-medium">See also:</span>
          <a href="https://batteries.fyi" class="hover:text-bp-text transition-colors">Batteries</a>
          <span class="text-bp-text-faint/50">·</span>
          <a href="https://cables.fyi" class="hover:text-bp-text transition-colors">Cables</a>
        </div>
        <div class="pt-4 flex justify-center mb-4">
          <a href="https://centricle.com" title="made by ksmith" aria-label="made by ksmith">
            <img src="https://centricle.com/brand/avatar-sm.jpg" alt="" width="28" height="28" class="w-7 h-7 rounded-full" loading="lazy" />
          </a>
        </div>
        <div class="flex items-center justify-between text-sm text-bp-text-faint">
          <span>&copy; {new Date().getFullYear()} fasteners.fyi</span>
        </div>
      </div>
    </footer>
  </body>
</html>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const button = document.getElementById('mobile-menu-button');
    const menu = document.getElementById('mobile-menu');
    if (!button || !menu) return;

    const hamburgerIcon = button.querySelector('.hamburger-icon');
    const closeIcon = button.querySelector('.close-icon');
    let isOpen = false;

    function toggleMenu() {
      isOpen = !isOpen;
      menu.classList.toggle('hidden', !isOpen);
      button.setAttribute('aria-expanded', isOpen.toString());
      button.setAttribute('aria-label', isOpen ? 'Close navigation menu' : 'Open navigation menu');
      if (hamburgerIcon && closeIcon) {
        hamburgerIcon.classList.toggle('hidden', isOpen);
        closeIcon.classList.toggle('hidden', !isOpen);
      }
      if (isOpen) {
        const firstLink = menu.querySelector('a');
        if (firstLink) firstLink.focus();
      } else {
        button.focus();
      }
    }

    function closeMenu() {
      if (isOpen) toggleMenu();
    }

    button.addEventListener('click', toggleMenu);
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && isOpen) closeMenu();
    });
    document.addEventListener('click', function(e) {
      if (isOpen && !menu.contains(e.target) && !button.contains(e.target)) closeMenu();
    });
    menu.addEventListener('click', function(e) {
      if (e.target.tagName === 'A') closeMenu();
    });
  });
</script>

<style is:global>
  @import "../styles/global.css";
</style>
